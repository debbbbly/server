# LiveKit Configuration
LIVEKIT_API_KEY=livekit-api-key-for-local-development
LIVEKIT_API_SECRET=livekit-api-secret-for-local-development

# PostgreSQL Configuration
DB_NAME=debbly
DB_USERNAME=debbly_user
DB_PASSWORD=debbly_password

# MinIO Configuration
MINIO_ROOT_USER=debbly_user
MINIO_ROOT_PASSWORD=debbly_password

# S3 Configuration for LiveKit Egress
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=debbly_user
S3_SECRET=debbly_password
S3_BUCKET=egress

# Note: After starting MinIO, you'll need to create the egress bucket. You can do this via:
# - The MinIO Console UI at http://localhost:9001
# - Or using the MinIO CLI (mc)
