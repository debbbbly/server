# LiveKit Development Configuration
LIVEKIT_API_KEY=devApiKey
LIVEKIT_API_SECRET=devApiSecret

# S3 Configuration for Egress (replace with your own values)
S3_ENDPOINT=https://your-storage-endpoint.com/storage/v1/s3
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET=your-secret-key
S3_BUCKET=egress