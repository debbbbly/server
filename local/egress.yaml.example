redis:
  address: localhost:6379

api_key: livekit-api-key-for-local-development
api_secret: livekit-api-secret-for-local-development
ws_url: ws://localhost:7880

s3:
  endpoint: https://your-object-storage-endpoint.example.com
  access_key: YOUR_S3_ACCESS_KEY
  secret: YOUR_S3_SECRET
  bucket: your-egress-bucket
  force_path_style: true

cpu_cost:
  room_composite_cpu_cost: 4.0

# Enable Prometheus metrics
prometheus_port: 9094
